<Window x:Class="Calculateur_Masque_Sous_Reseau.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculateur de Masque Réseau"
        Height="700" Width="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2980B9" Padding="15,10">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Calculateur de Masque Réseau" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,2"/>
                <TextBlock Text="SAÉ S2 - IUT Informatique Amiens | Année 2026" FontSize="11" Foreground="#EBF5FB"/>
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="1" Header=" Saisie Configuration Réseau " Margin="15,10,15,5" Foreground="#2C3E50" FontWeight="Bold">
            <StackPanel Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Adresse IPv4 :" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                    <TextBox x:Name="txtIP" Grid.Column="1" Height="25" VerticalContentAlignment="Center" Margin="5,0"/>
                    <Label Content="Masque CIDR : /" Grid.Column="2" VerticalAlignment="Center" FontWeight="Normal" Margin="10,0,0,0"/>
                    <TextBox x:Name="txtCIDR" Grid.Column="3" Height="25" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    <Button x:Name="btnCalculer" Content="Calculer" Grid.Column="4" HorizontalAlignment="Right" Width="110" Height="28"
                            Background="#2ECC71" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnCalculer_Click"/>
                </Grid>
                <TextBlock x:Name="lblErreur" Text="" Foreground="Red" FontSize="11" FontWeight="Bold" FontStyle="Italic" Margin="5,8,0,0"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header=" Résultats de l'Analyse Réseau " Margin="15,5,15,5" Foreground="#2C3E50" FontWeight="Bold">
            <Grid Margin="10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="24"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Classe IP :" Grid.Row="0" VerticalAlignment="Center" FontWeight="Normal" Foreground="#34495E"/>
                <TextBlock x:Name="lblClasseVal" Text="-" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Foreground="#2C3E50" FontWeight="SemiBold"/>
                <TextBlock Text="Adresse Réseau (@net) :" Grid.Row="1" VerticalAlignment="Center" FontWeight="Normal" Foreground="#34495E"/>
                <TextBlock x:Name="lblNetVal" Text="-" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Foreground="#2C3E50" FontWeight="SemiBold"/>
                <TextBlock Text="Adresse Broadcast (@Broadcast) :" Grid.Row="2" VerticalAlignment="Center" FontWeight="Normal" Foreground="#34495E"/>
                <TextBlock x:Name="lblBroadcastVal" Text="-" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Foreground="#2C3E50" FontWeight="SemiBold"/>
                <TextBlock Text="Première IP (1er IP) :" Grid.Row="3" VerticalAlignment="Center" FontWeight="Normal" Foreground="#34495E"/>
                <TextBlock x:Name="lblFirstIPVal" Text="-" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Foreground="#2C3E50" FontWeight="SemiBold"/>
                <TextBlock Text="Dernière IP :" Grid.Row="4" VerticalAlignment="Center" FontWeight="Normal" Foreground="#34495E"/>
                <TextBlock x:Name="lblLastIPVal" Text="-" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Foreground="#2C3E50" FontWeight="SemiBold"/>
                <TextBlock Text="Nombre Total d'IPs (Nb IPs) :" Grid.Row="5" VerticalAlignment="Center" FontWeight="Normal" Foreground="#34495E"/>
                <TextBlock x:Name="lblNbIPsVal" Text="-" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" Foreground="#2C3E50" FontWeight="SemiBold"/>
                <TextBlock Text="Nombre de Machines (Nb machines) :" Grid.Row="6" VerticalAlignment="Center" FontWeight="Normal" Foreground="#34495E"/>
                <TextBlock x:Name="lblNbMachinesVal" Text="-" Grid.Row="6" Grid.Column="1" VerticalAlignment="Center" Foreground="#2C3E50" FontWeight="SemiBold"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header=" Conversions Systèmes (Binaire &amp; Hexa) " Margin="15,5,15,5" Foreground="#2C3E50" FontWeight="Bold">
            <Grid Margin="10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                </Grid.RowDefinitions>
                <TextBlock Text="IP en Binaire :" Grid.Row="0" VerticalAlignment="Center" FontWeight="Normal" Foreground="#34495E"/>
                <TextBlock x:Name="lblIpBinaireVal" Text="-" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Foreground="#2C3E50" FontFamily="Consolas"/>
                <TextBlock Text="IP en Hexadécimal :" Grid.Row="1" VerticalAlignment="Center" FontWeight="Normal" Foreground="#34495E"/>
                <TextBlock x:Name="lblIpHexaVal" Text="-" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Foreground="#2C3E50" FontFamily="Consolas"/>
                <TextBlock Text="Masque en Binaire :" Grid.Row="2" VerticalAlignment="Center" FontWeight="Normal" Foreground="#34495E"/>
                <TextBlock x:Name="lblMasqueBinaireVal" Text="-" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Foreground="#2C3E50" FontFamily="Consolas"/>
                <TextBlock Text="Masque sur 4 octets :" Grid.Row="3" VerticalAlignment="Center" FontWeight="Normal" Foreground="#34495E"/>
                <TextBlock x:Name="lblMasqueOctetsVal" Text="-" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Foreground="#2C3E50"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="4" Header=" Informations Projet " Margin="15,5,15,15" Foreground="#2C3E50" FontWeight="Bold">
            <TextBlock Text="Étudiants : Duyck, Boutot, Manoranjith, Fontal, Sicard | BUT 1 Amiens | Année : 2026" Foreground="#7F8C8D" VerticalAlignment="Center" HorizontalAlignment="Center" FontStyle="Italic"/>
        </GroupBox>
    </Grid>
</Window>